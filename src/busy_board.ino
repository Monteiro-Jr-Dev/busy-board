          sub_etapa_ciclo = 1;
        }else{
          leds_on_03 = B00000001 << estagio | leds_on_03;
          offset_ciclo_parcial_chaser += tamanho_ciclo_parcial_chaser * 2;
          tamanho_ciclo_parcial_chaser--;
          sub_etapa_ciclo = 0;
          if(tamanho_ciclo_parcial_chaser - 1 == 0){
            tamanho_ciclo_parcial_chaser = 12;
            leds_on_01 = B00000000;
            leds_on_02 = B00000000;
            leds_on_03 = B00000000;
        }
        }
      }
      break;

    case 8:
    case 9:
    case 10:
    case 11:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000 | leds_on_01);
      if(sub_etapa_ciclo == 0){
        shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B10000000 >> estagio - 8 | leds_on_02);
      } else {
        shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << estagio - 8 | leds_on_02);
      }
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000 | leds_on_03);
      digitalWrite(PIN_D_8, HIGH);

      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;

      // Atualiza os leds e tamanho do ciclo da proxima rodada
      if(estagio == (tamanho_ciclo_parcial_chaser - 1)){
        if(sub_etapa_ciclo == 0){
          leds_on_02 = B10000000 >> estagio - 8 | leds_on_02;
          sub_etapa_ciclo = 1;
        } else {
          leds_on_02 = B00000001 << estagio - 8 | leds_on_02;
          offset_ciclo_parcial_chaser += tamanho_ciclo_parcial_chaser * 2;
          tamanho_ciclo_parcial_chaser--;
          sub_etapa_ciclo = 0;
        }
      }
      break;
    }
  }

  return false;
}

void limpar_chaser()
{
  digitalWrite(PIN_D_8, LOW);
  shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
  shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
  shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
  digitalWrite(PIN_D_8, HIGH);
}

