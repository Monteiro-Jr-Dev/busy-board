void novo_padrao_musical()
{
  short int novo_padrao;

  do
  {
    novo_padrao = random(0, quant_total_padroes);
  } while (novo_padrao == padrao_atual_musical);

  multiplicador_ciclos_musical = random(1, 4);
  estagio_atual_musical = 255;
  padrao_atual_musical = novo_padrao;
}

bool led_musical_padrao_00()
{
  if (estagio_atual_musical == 255)
  {
    tempo_estagio_musical = currentMillis;
    estagio_atual_musical = 0;
  }

  short int tamanho_ciclo = 2 * multiplicador_ciclos_musical; // quantidade de estágios do padrao
  short int delay_entre_estagios = 1500;
  short int estagio = estagio_atual_musical % 2;


  if (currentMillis - tempo_estagio_musical >= delay_entre_estagios || estagio_atual_musical == 0)
  {

    if (estagio_atual_musical >= tamanho_ciclo)
    {
      return true;
    }

    switch (estagio)
    {

    case 0:
      digitalWrite(PIN_D_7, LOW);
      shiftOut(PIN_D_6, PIN_D_5, LSBFIRST, B10101000);
      digitalWrite(PIN_D_7, HIGH);
      tempo_estagio_musical = currentMillis;
      estagio_atual_musical++;
      break;

    case 1:
      digitalWrite(PIN_D_7, LOW);
      shiftOut(PIN_D_6, PIN_D_5, LSBFIRST, B01010100);
      digitalWrite(PIN_D_7, HIGH);
      tempo_estagio_musical = currentMillis;
      estagio_atual_musical++;
      break;
    }
  }

  return false;
}

