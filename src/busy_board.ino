void setup()
{
  // Serial for debug
  // Serial.begin(9600);

  // inicializar pinos
  pinMode(LED_BUILTIN, OUTPUT);
  pinMode(PIN_D_0, OUTPUT);
  pinMode(PIN_D_1, OUTPUT);
  pinMode(PIN_D_2, OUTPUT);
  pinMode(PIN_D_3, OUTPUT);
  pinMode(PIN_D_4, INPUT_PULLUP);
  pinMode(PIN_D_5, OUTPUT);
  pinMode(PIN_D_6, OUTPUT);
  pinMode(PIN_D_7, OUTPUT);
  pinMode(PIN_D_8, OUTPUT);
  pinMode(PIN_A_0, INPUT);

  // Inicializar Variaveis da campainha
  tempoCampainha = 0;
  intervaloCampainha = 40;
  estagioCampainha = 0;

  // Inicializar Variaveis ventilador
  potenciometroVentilador = 0;
  velMin = 18;
  velMax = 30;
  tranco = 50;
  tempo_tranco = millis();
  tranco_ativo = false;

  // Inicializar display OLed
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.setTextColor(WHITE);
  display.setTextWrap(false);
  //posModo = posNome = display.width();
  // minModo = -(6 * textSizeModo) * strlen(message);  // 6 pixels per character * text size
  //minNome = -(6 * textSizeNome) * (strlen(nome) + 1); // 6 pixels per character * text size
  display.clearDisplay();
  display.display();

  // Inicializar Joystick
  // modoAtual = modo_joystick();
  // modo_mudou = false;

  // Inicializar Led Chaser
  seletor_atual = digitalRead(PIN_D_4);
  seletor_mudou = false;
  digitalWrite(LED_BUILTIN, HIGH);
  tempo_mudou = millis();
  limpar_chaser();
  padrao_atual_chaser = 0;
  estagio_atual_chaser = -1;
  tempo_estagio_chaser = 0;
  multiplicador_ciclos_chaser = 1;
  quant_total_padroes_chaser = 13;
  painel_on = false;
  //tempo_painel_on = currentMillis;

  // Inicializar Musical
  padrao_atual_musical = 0;
  estagio_atual_musical = 255;
  tempo_estagio_musical = millis();
  quant_total_padroes = 8;
  multiplicador_ciclos_musical = 1;

  // Inicializar Animação
  animacao_atual = 0;
  frame_atual = 0;
}

void loop()
{
  // Update time
  currentMillis = millis();

  // Verifica se a chave seletora multimetro mudou
  seletor_mudou = mudanca_seletor();
  if (seletor_mudou)
  {
    novo_padrao_chaser();
    ligar_painel();
    nova_animacao();
    seletor_mudou = 0;
  }
  // chama funções
  campainha();
  ventilador();
  // display_oled();
  led_chaser();
  led_musical();
  animacao();
  // modo_mudou = mudanca_modo(); // Desativado pois joystick ainda não foi conectado
  // Verifica se deu tempo de desligar o led chaser e oled
  // tempo_chaser();
}
