bool led_chaser_padrao_11()
{
  short int tamanho_ciclo = 77 * multiplicador_ciclos_chaser; // quantidade de estágios do padrao
  short int delay_entre_estagios = 50;

  if (estagio_atual_chaser == -1)
  {
    tempo_estagio_chaser = millis() + delay_entre_estagios;
    estagio_atual_chaser = 0;
    tamanho_ciclo_parcial_chaser = 12;
    offset_ciclo_parcial_chaser = 0;
    leds_on_01 = B00000000;
    leds_on_02 = B00000000;
    leds_on_03 = B00000000;
  }

  short int estagio = (estagio_atual_chaser - offset_ciclo_parcial_chaser) % tamanho_ciclo_parcial_chaser;

  if (millis() - tempo_estagio_chaser >= delay_entre_estagios)
  {

    if (estagio_atual_chaser >= tamanho_ciclo)
    {
      return true;
    }

    switch (estagio)
    {

    case 0:
    case 1:
    case 2:
    case 3:
    case 4:
    case 5:
    case 6:
    case 7:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B10000000 >> estagio | leds_on_01);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000 | leds_on_02);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << estagio | leds_on_03);
      digitalWrite(PIN_D_8, HIGH);
      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;
      // Atualiza os leds da proxima rodada
      if(estagio == (tamanho_ciclo_parcial_chaser - 1)){
        leds_on_01 = (B10000000 >> estagio) | leds_on_01;
        leds_on_03 = (B00000001 << estagio) | leds_on_03;
        offset_ciclo_parcial_chaser += tamanho_ciclo_parcial_chaser;
        tamanho_ciclo_parcial_chaser--;
        if(tamanho_ciclo_parcial_chaser - 1 == 0){
          tamanho_ciclo_parcial_chaser = 12;
          leds_on_01 = B00000000;
          leds_on_02 = B00000000;
          leds_on_03 = B00000000;
        }
      }
      break;

    case 8:
    case 9:
    case 10:
    case 11:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000 | leds_on_01);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << estagio - 8 | B10000000 >> estagio - 8 | leds_on_02);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000 | leds_on_03);
      digitalWrite(PIN_D_8, HIGH);
      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;

      // Atualiza os leds e tamanho do ciclo da proxima rodada
      if(estagio == (tamanho_ciclo_parcial_chaser - 1)){
        leds_on_02 = (B00000001 << estagio - 8) | (B10000000 >> estagio - 8) | leds_on_02;
        offset_ciclo_parcial_chaser += tamanho_ciclo_parcial_chaser;
        tamanho_ciclo_parcial_chaser--;
      }

      break;
    }
  }

  return false;
}

