void campainha()
{
  // Check if it's time to change the cycle
  if ((currentMillis - tempoCampainha) >= intervaloCampainha)
  {
    tempoCampainha = currentMillis;
    // Check which stage is going to be executed
    if (estagioCampainha == 0)
    {
      digitalWrite(PIN_D_0, LOW);
      digitalWrite(PIN_D_1, HIGH);
      estagioCampainha = 1;
    }
    else
    {
      digitalWrite(PIN_D_1, LOW);
      digitalWrite(PIN_D_0, HIGH);
      estagioCampainha = 0;
    }
  }
}

void ventilador()
{
  // Gambiarra para evitar que o ventilador fique agarrado
  if (tranco_ativo)
  {
    analogWrite(PIN_D_3, tranco);
    if ((currentMillis - tempo_tranco) >= 100)
    {
      tranco_ativo = false;
      tempo_tranco = currentMillis;
    }
  }
  else
  {
    potenciometroVentilador = analogRead(PIN_A_0);
    analogWrite(PIN_D_3, map(potenciometroVentilador, 0, 1023, velMin, velMax));
    if ((currentMillis - tempo_tranco) >= 3000 && potenciometroVentilador < 512)
    {
      tranco_ativo = true;
      tempo_tranco = currentMillis;
    }
  }
}

