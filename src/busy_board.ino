void ligar_painel()
{
  painel_on = true;
  //tempo_painel_on = currentMillis;
}

void nova_animacao()
{

  if (animacao_atual == 1)
  {
    animacao_atual = 0;
    return;
  }
  animacao_atual = 1;
}

void animacao()
{
  if (!painel_on)
    return;
  switch (animacao_atual)
  {
  case 0:
    animacao_00();
    break;

  case 1:
    animacao_01();
    break;
  }
}

void animacao_00()
{
  display.clearDisplay();
  display.drawBitmap(32, 0, frames_animacao_00[frame_atual], FRAME_WIDTH, FRAME_HEIGHT, 1);
  display.display();
  frame_atual = (frame_atual + 1) % frame_count_animacao_00;
}

void animacao_01()
{
  display.clearDisplay();
  // Imprime Título
  display.setTextSize(2);
  display.setCursor(0, 0);
  display.print(F("Painel de "));
  // Imprime nome
  display.setTextSize(5);
  display.setCursor(0, 20);
  display.print(F("TUTU"));
  display.display();
}

