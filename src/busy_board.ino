void novo_padrao_chaser()
{

  short int novo_padrao;

  do
  {
    novo_padrao = random(0, quant_total_padroes_chaser);
  } while (novo_padrao == padrao_atual_chaser);
  estagio_atual_chaser = -1;
  padrao_atual_chaser = novo_padrao;
  multiplicador_ciclos_chaser = random(2, 5);

  //multiplicador_ciclos_chaser = 3; // for test only
  //padrao_atual_chaser = 11;
}

bool led_chaser_padrao_00()
{
  short int tamanho_ciclo = 24 * multiplicador_ciclos_chaser; // quantidade de estágios do padrao
  short int delay_entre_estagios = 75;

  if (estagio_atual_chaser == -1)
  {
    tempo_estagio_chaser = millis() + delay_entre_estagios;
    estagio_atual_chaser = 0;
  }

  short int estagio = estagio_atual_chaser % 24;

  if (millis() - tempo_estagio_chaser >= delay_entre_estagios)
  {

    if (estagio_atual_chaser >= tamanho_ciclo)
    {
      return true;
    }

    switch (estagio)
    {

    case 0:
    case 1:
    case 2:
    case 3:
    case 4:
    case 5:
    case 6:
    case 7:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << estagio);
      digitalWrite(PIN_D_8, HIGH);

      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;
      break;

    case 8:
    case 9:
    case 10:
    case 11:
    case 12:
    case 13:
    case 14:
    case 15:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << (estagio - 8));
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      digitalWrite(PIN_D_8, HIGH);

      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;
      break;

    case 16:
    case 17:
    case 18:
    case 19:
    case 20:
    case 21:
    case 22:
    case 23:
      digitalWrite(PIN_D_8, LOW);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000001 << (estagio - 16));
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      shiftOut(PIN_D_2, PIN_D_5, LSBFIRST, B00000000);
      digitalWrite(PIN_D_8, HIGH);

      tempo_estagio_chaser = millis();
      estagio_atual_chaser++;
      break;
    }
  }

  return false;
}

